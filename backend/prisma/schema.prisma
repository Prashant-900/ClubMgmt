// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINATOR
  MEMBER
}

enum ContributionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContributionCategory {
  DEVELOPMENT
  WORKSHOP
  PRESENTATION
  DESIGN
  EVENT_SUPPORT
  DOCUMENTATION
  MEETING
  OTHER
}

model Club {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  users         User[]
  inviteLinks   InviteLink[]
  contributions Contribution[]

  @@map("clubs")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String?
  name       String?
  phone      String?
  role       Role     @default(MEMBER)
  isVerified Boolean  @default(false)

  // Club — required for COORDINATOR and MEMBER, null for ADMIN
  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id])

  // Invitation hierarchy tracking
  invitedById String?
  invitedBy   User?   @relation("Invitations", fields: [invitedById], references: [id])
  invitees    User[]  @relation("Invitations")

  // Invite links created by this user
  createdInviteLinks InviteLink[]

  // Contributions submitted by this user
  contributions Contribution[] @relation("UserContributions")

  // Contributions approved/rejected by this user
  approvedContributions Contribution[] @relation("Approvals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model InviteLink {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  role      Role     @default(MEMBER)
  maxUses   Int
  usedCount Int      @default(0)
  expiresAt DateTime

  // Club — assigned to registrants (null for admin-created general links)
  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id])

  // Who created this link (optional — null for local-admin dev bypass)
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@map("invite_links")
}

model Contribution {
  id            String               @id @default(uuid())
  userId        String
  user          User                 @relation("UserContributions", fields: [userId], references: [id], onDelete: Cascade)
  clubId        String
  club          Club                 @relation(fields: [clubId], references: [id])
  title         String
  description   String?
  category      ContributionCategory
  hours         Float
  datePerformed DateTime
  attachmentUrl String?

  status          ContributionStatus @default(PENDING)
  rejectionReason String?

  approvedById String?
  approvedBy   User?     @relation("Approvals", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contributions")
}

